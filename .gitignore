# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which may contain secrets
*.tfvars
*.tfvars.json

# Ignore override files (local-only overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration and credential files
.terraformrc
terraform.rc

# Lock file is committed for root modules but ignored for reusable modules
.terraform.lock.hcl

# Plan output files
*.tfplan
*.plan

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
